import java.nio.charset.StandardCharsets;
import java.nio.file.Files;
import java.nio.file.Path;
import java.nio.file.Paths;
import java.util.LinkedHashMap;
import java.util.List;
import java.util.Map;

/** Verifies that missingcodes() survives the privacy-safe completion reduction. */
public final class CompletionMissingContractTest {
    private CompletionMissingContractTest() {}

    public static void main(String[] args) throws Exception {
        if (args.length != 1) throw new IllegalArgumentException("Expected project root.");
        Path root = Paths.get(args[0]).toAbsolutePath().normalize();
        require(Files.isRegularFile(root.resolve("surveye_2_0_0.jar")),
                "Release engine JAR is missing from project root: " + root);
        Path temporary = Files.createTempDirectory("surveye-completion-missing-");
        try {
            Path questionnaire = temporary.resolve("questionnaire.html");
            Files.write(questionnaire, questionnaire().getBytes(StandardCharsets.UTF_8));
            Path data = temporary.resolve("completion.csv");
            Files.write(data, ("case_id,completion_case\n"
                    + "1,1\n"
                    + "2,-9\n"
                    + "3,\n").getBytes(StandardCharsets.UTF_8));

            Path output = temporary.resolve("completion.html");
            Path status = temporary.resolve("status.tsv");
            Path config = temporary.resolve("config.tsv");
            String settings = "mode\tbuild\n"
                    + "questionnaire\t" + questionnaire + "\n"
                    + "data\t" + data + "\n"
                    + "output\t" + output + "\n"
                    + "status\t" + status + "\n"
                    + "variables\tcompletion_case\n"
                    + "missingcodes\t-9\n"
                    + "replace\t1\n";
            Files.write(config, settings.getBytes(StandardCharsets.UTF_8));

            int returnCode = org.worldbank.surveye.StataPlugin.stata(new String[]{config.toString()});
            require(returnCode == 0, "stata() did not use the status-file contract: " + returnCode);
            Map<String, String> values = readStatus(status);
            require("1".equals(values.get("success")), "Completion build failed: " + values);
            require("3".equals(values.get("N")), "Unexpected observation count: " + values);
            require("1".equals(values.get("k_charted")), "Unexpected chart count: " + values);

            String html = new String(Files.readAllBytes(output), StandardCharsets.UTF_8);
            require(html.contains("data-variable=\"completion_case\" data-kind=\"completion\""),
                    "The explicit text item did not use the completion path.");
            String dataPayload = payload(html, "var DATA=", ";\n");
            require("[{\"completion_case\":true},{\"completion_case\":null},{\"completion_case\":null}]"
                            .equals(dataPayload),
                    "Completion reduction did not map valid/-9/blank to true/null/null: " + dataPayload);
            System.out.println("PASS completion missing-code reduction (valid/-9/blank -> true/null/null)");
        } finally {
            deleteTree(temporary);
        }
    }

    private static String questionnaire() {
        return "<!doctype html><html lang=\"en\"><head><meta charset=\"utf-8\">"
                + "<title>Completion missing contract</title></head><body>"
                + "<div class=\"questionnaire_title\"><h1>Completion missing contract</h1></div>"
                + "<section class=\"section\"><div class=\"section_header\"><h2>Interview</h2></div>"
                + "<div class=\"question-container\"><div class=\"question\"><div class=\"question-title\">"
                + "<span>C</span>Completion source</div></div><div class=\"answer\">"
                + "<div class=\"question-meta\"><div class=\"type\">text</div>"
                + "<div class=\"variable_name\">completion_case</div></div>"
                + "<div class=\"answer-editor\"></div></div></div></section></body></html>";
    }

    private static String payload(String html, String startToken, String endToken) {
        int start = html.indexOf(startToken);
        int end = start < 0 ? -1 : html.indexOf(endToken, start + startToken.length());
        require(start >= 0 && end > start, "Generated HTML has no readable DATA payload.");
        return html.substring(start + startToken.length(), end);
    }

    private static Map<String, String> readStatus(Path filename) throws Exception {
        Map<String, String> values = new LinkedHashMap<String, String>();
        List<String> lines = Files.readAllLines(filename, StandardCharsets.UTF_8);
        for (String line : lines) {
            int tab = line.indexOf('\t');
            require(tab > 0, "Malformed status record: " + line);
            values.put(line.substring(0, tab), line.substring(tab + 1));
        }
        return values;
    }

    private static void require(boolean condition, String message) {
        if (!condition) throw new AssertionError(message);
    }

    private static void deleteTree(Path root) throws Exception {
        if (!Files.exists(root)) return;
        try (java.util.stream.Stream<Path> stream = Files.walk(root)) {
            Path[] paths = stream.sorted(java.util.Comparator.reverseOrder()).toArray(Path[]::new);
            for (Path path : paths) Files.deleteIfExists(path);
        }
    }
}
